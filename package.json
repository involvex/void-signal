{
	"name": "void-signal",
	"version": "0.1.0",
	"private": true,
	"description": "A terminal-based ASCII RPG with colored tile rendering, turn-based combat, NPCs, and branching dialogue",
	"repository": {
		"type": "git",
		"url": "git+ https://github.com/involvex/void-signal.git"
	},
	"funding": {
		"url": "https://github.com/sponsors/involvex"
	},
	"author": "involvex",
	"type": "module",
	"module": "index.ts",
	"bin": {
		"void-signal": "src/main.ts"
	},
	"scripts": {
		"prebuild": "bun run format && bun run lint:fix && bun run typecheck",
		"build": "bun build src/main.ts --outdir dist --target bun",
		"dev": "bun --watch run src/main.ts",
		"format": "prettier . --write",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"start": "bun run src/main.ts",
		"typecheck": "tsc --noEmit"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@xterm/headless": "^6.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@involvex/prettier-config": "^0.0.4",
		"@types/bun": "latest",
		"@types/node": "^25.5.0",
		"eslint": "^10.1.0",
		"prettier": "^3.8.1",
		"typescript-eslint": "^8.57.2"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"sponsor": {
		"url": "https://github.com/sponsors/involvex"
	}
}
